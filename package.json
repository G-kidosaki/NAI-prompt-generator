{
  "name": "nai-prompt-generator-pwa",
  "version": "1.0.0",
  "description": "NovelAI プロンプト生成ツール (PWA)",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && gh-pages -d dist",
    "dev:ext": "vite --config vite.config.ext.js",
    "build:ext": "vite build --config vite.config.ext.js",
    "pack:ext": "cd dist-ext && zip -r ../nai-prompt-extension.zip . && cd .."
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.33",
    "@vitejs/plugin-react": "^4.3.4",
    "gh-pages": "^6.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.1"
  }
}
